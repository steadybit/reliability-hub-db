#!/usr/bin/env bash

if ! command -v jq &> /dev/null; then
  echo "pre-commit: jq is required but not installed. Install it via 'brew install jq' or 'apt-get install jq'." >&2
  exit 1
fi

list_paths() {
  printf '%s\n' "$1"/*/"$2" | jq -R '"/\(.)"' | jq -s .
}

new_content=$(jq -n \
  --argjson templates "$(list_paths templates template.json)" \
  --argjson actions "$(list_paths actions description.yml)" \
  --argjson extensions "$(list_paths extensions description.yml)" \
  '{templates: $templates, actions: $actions, extensions: $extensions}')

old_content=$(jq 'del(.lastChange)' index.json 2>/dev/null)

if [ "$new_content" != "$old_content" ]; then
  echo "$new_content" | jq --argjson ts "$(date +%s)" '{lastChange: $ts} + .' > index.json
  git add index.json
fi